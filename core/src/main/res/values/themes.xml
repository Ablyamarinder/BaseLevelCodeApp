<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.NewSampleApp" parent="android:Theme.Material.Light.NoActionBar" />
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar"/>
    <!-- res/values/themes.xml -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- Set background, icon, and icon background color -->
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        <!-- Set the theme for the app to switch to -->
        <item name="windowSplashScreenAnimationDuration">5000</item>
        <item name="postSplashScreenTheme">@style/Theme.NewSampleApp</item>
    </style>
</resources>